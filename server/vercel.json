{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node",
      "config": {
        "maxLambdaSize": "50mb",
        "includeFiles": [
          "public/**",
          "node_modules/@titaniumnetwork-dev/ultraviolet/dist/**",
          "node_modules/@mercuryworkshop/bare-mux/dist/**",
          "node_modules/@mercuryworkshop/bare-as-module3/dist/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "index.js"
    }
  ]
}

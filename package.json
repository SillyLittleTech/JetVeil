{
  "name": "jetveil",
  "version": "1.0.0",
  "private": true,
  "description": "JetVeil multiplatform desktop web wrapper with local ScramJet proxy.",
  "scripts": {
    "install:all": "npm --prefix server install && npm --prefix desktop install",
    "dev": "npm --prefix desktop run dev",
    "dev:headless": "npm --prefix desktop run dev:headless",
    "pack": "npm --prefix desktop run pack",
    "build": "npm --prefix desktop run build",
    "build:linux": "npm --prefix desktop run build:linux",
    "build:windows": "npm --prefix desktop run build:windows",
    "build:mac": "npm --prefix desktop run build:mac",
    "build:mac:dmg": "npm --prefix desktop run build:mac:dmg",
    "server:dev": "npm --prefix server run dev",
    "server:start": "npm --prefix server run start"
  }
}
